---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamView from '../../components/views/TeamView.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={`${t.seo.team.title} · ${t.meta.siteName}`} description={t.seo.team.description}>
  <TeamView lang={lang} />
</BaseLayout>
