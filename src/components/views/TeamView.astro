---
import { getCollection } from 'astro:content';
import TeamCard from '../team/TeamCard.astro';
import { useTranslations, type Lang } from '../../i18n/utils';
import { EXTERNAL_LINKS } from '../../config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const order = ['pi', 'core', 'training', 'advisor', 'collaborator'] as const;
const members = await getCollection('team');
const groups = order
  .map((cat) => ({
    cat,
    label: t.team.categories[cat],
    items: members
      .filter((m) => m.data.category === cat)
      .sort((a, b) => a.data.order - b.data.order),
  }))
  .filter((g) => g.items.length > 0);
---

<section class="section">
  <div class="container">
    <div class="section__intro">
      <p class="eyebrow">{t.meta.siteName}</p>
      <h1>{t.team.title}</h1>
      <p>{t.team.intro}</p>
    </div>

    {
      groups.map((group) => (
        <div class="team-group">
          <h2 class="team-group__title">{group.label}</h2>
          <div class="team-grid">
            {group.items.map((entry) => (
              <TeamCard entry={entry} lang={lang} />
            ))}
          </div>
        </div>
      ))
    }

    <div class="team-cta">
      <a class="btn btn--outline" href={EXTERNAL_LINKS.premind} target="_blank" rel="noopener noreferrer">
        {t.team.premindCta} →
      </a>
    </div>
  </div>
</section>

<style>
  .team-group {
    margin-top: var(--space-16);
  }
  .team-group__title {
    padding-bottom: var(--space-3);
    border-bottom: 2px solid var(--color-border);
    margin-bottom: var(--space-8);
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 16rem), 1fr));
    gap: var(--space-8);
  }
  .team-cta {
    margin-top: var(--space-16);
    text-align: center;
  }
</style>
