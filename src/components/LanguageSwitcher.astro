---
import { getAlternateLinks, getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const alternates = getAlternateLinks(Astro.url);
---

<div class="lang-switch" role="group" aria-label={t.a11y.switchLang}>
  {
    alternates.map((alt) => (
      <a
        href={alt.path}
        hreflang={alt.hreflang}
        lang={alt.lang}
        aria-current={alt.lang === lang ? 'true' : undefined}
        class:list={['lang-switch__item', { 'is-active': alt.lang === lang }]}
      >
        {alt.lang.toUpperCase()}
      </a>
    ))
  }
</div>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.125rem;
    background: var(--color-surface);
  }
  .lang-switch__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-full);
    font-size: var(--fs-300);
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    transition:
      background var(--transition),
      color var(--transition);
  }
  .lang-switch__item:hover {
    color: var(--color-primary);
  }
  .lang-switch__item.is-active {
    background: var(--color-primary);
    color: var(--color-on-primary);
  }
</style>
