---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { useTranslations, pickLocalized, type Lang } from '../../i18n/utils';

interface Props {
  entry: CollectionEntry<'team'>;
  lang: Lang;
}
const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const d = entry.data;
const role = pickLocalized(d.role, lang);
const bio = pickLocalized(d.bio, lang);
const initials = d.name
  .split(/\s+/)
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase() ?? '')
  .join('');

const linkLabels = t.team.links;
const links = (
  d.links ? Object.entries(d.links).filter(([, v]) => Boolean(v)) : []
) as [keyof typeof linkLabels, string][];
---

<article class="member card">
  <div class="member__photo">
    {
      d.photo ? (
        <Image src={d.photo} alt={d.name} width={240} height={240} />
      ) : (
        <span class="member__initials" aria-hidden="true">
          {initials}
        </span>
      )
    }
  </div>
  <h3 class="member__name">{d.name}</h3>
  <p class="member__role">{role}</p>
  {bio && <p class="member__bio">{bio}</p>}
  {
    links.length > 0 && (
      <ul class="member__links" role="list">
        {links.map(([key, url]) => (
          <li>
            <a href={url} target="_blank" rel="noopener noreferrer">
              {linkLabels[key]}
            </a>
          </li>
        ))}
      </ul>
    )
  }
</article>

<style>
  .member {
    display: grid;
    gap: var(--space-2);
    text-align: center;
    justify-items: center;
  }
  .member__photo {
    width: 7.5rem;
    height: 7.5rem;
    border-radius: var(--radius-full);
    overflow: hidden;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    margin-bottom: var(--space-2);
  }
  .member__photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .member__initials {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  .member__name {
    font-size: var(--fs-500);
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--color-primary);
  }
  .member__role {
    color: var(--color-accent-dark);
    font-weight: 600;
    font-size: var(--fs-300);
  }
  .member__bio {
    color: var(--color-text-muted);
    font-size: var(--fs-400);
  }
  .member__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-2);
    list-style: none;
    padding: 0;
    font-size: var(--fs-300);
    font-weight: 600;
  }
</style>
