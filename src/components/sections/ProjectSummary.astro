---
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section" id="about">
  <div class="container summary">
    <div class="summary__text">
      <p class="eyebrow">{t.meta.siteName}</p>
      <h2>{t.summary.heading}</h2>
      <p class="lead summary__lead">{t.summary.lead}</p>
      <p class="summary__body">{t.summary.body}</p>
    </div>

    <aside class="summary__challenges card" aria-labelledby="challenges-heading">
      <h3 id="challenges-heading" class="summary__challenges-title">
        {t.summary.challengesHeading}
      </h3>
      <ul role="list" class="summary__list">
        {t.summary.challenges.map((c) => <li>{c}</li>)}
      </ul>
    </aside>
  </div>
</section>

<style>
  .summary {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }
  .summary__lead {
    margin-top: var(--space-4);
    color: var(--color-text);
    font-weight: 500;
  }
  .summary__body {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
  }
  .summary__challenges {
    border-top: 4px solid var(--color-accent);
  }
  .summary__challenges-title {
    font-size: var(--fs-500);
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--color-primary);
  }
  .summary__list {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }
  .summary__list li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--color-text);
  }
  .summary__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 2px;
    background: var(--color-accent);
  }

  @media (max-width: 52em) {
    .summary {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
